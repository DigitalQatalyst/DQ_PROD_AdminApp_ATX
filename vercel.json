{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/crm-webhook.ts",
      "use": "@vercel/node"
    }
  ],
  "env": {
    "VITE_USE_MOCK_AUTH": "true",
    "VITE_ENVIRONMENT": "dev",
    "AUTH_MODE": "mock",
    "USE_MOCK_AUTH": "true"
  },
  "routes": [
    {
      "src": "/api/crm-webhook",
      "dest": "/api/crm-webhook.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
